{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": [
          {
            "regexp": "^✘ \\[ERROR\\] (.*)$",
            "message": 1
          },
          {
            "regexp": "^\\s+([^:]+):(\\d+):(\\d+):$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started",
          "endsPattern": "^\\[watch\\] build finished"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "npm: watch"
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": [
          {
            "regexp": "^✘ \\[ERROR\\] (.*)$",
            "message": 1
          },
          {
            "regexp": "^\\s+([^:]+):(\\d+):(\\d+):$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      },
      "group": "build",
      "presentation": {
        "reveal": "silent"
      },
      "label": "npm: compile"
    }
  ]
}