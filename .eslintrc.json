{
  "env": {
    "es2021": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": [
    "out/",
    "node_modules/",
    "media/webview/app.js",
    "media/webview/app.js.map",
    "media/src/",
    "media/main.ts",
    "media/app-backup.ts"
  ],
  "overrides": [
    {
      // Extension + src — Node environment
      "files": ["src/**/*.ts"],
      "env": { "node": true },
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
      ]
    },
    {
      // WebView — Browser environment
      "files": ["media/webview/*.ts"],
      "env": { "browser": true },
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
      ]
    },
    {
      // Tests — Node + ignore no-var-requires
      "files": ["src/**/__tests__/**/*.ts"],
      "env": { "node": true, "jest": true },
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
      ],
      "rules": {
        "@typescript-eslint/no-var-requires": "off",
        "@typescript-eslint/no-unused-vars": "warn"
      }
    },
    {
      // esbuild.js + bin/ — Node CommonJS
      "files": ["esbuild.js", "bin/**/*.js"],
      "env": { "node": true },
      "parserOptions": {
        "sourceType": "script"
      }
    }
  ]
}