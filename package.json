{
  "name": "dotshare",
  "displayName": "DotShare",
  "description": "The Ultimate Publishing Suite: Share your code/ideas across multiple social and blogging platforms directly from VS Code.",
  "version": "3.1.0",
  "publisher": "freerave",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/kareem2099"
    },
    {
      "type": "custom",
      "url": "https://www.buymeacoffee.com/freerave"
    },
    {
      "type": "custom",
      "url": "https://paypal.me/freerave1"
    }
  ],
  "engines": {
    "vscode": "^1.74.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "icon": "assets/icons/icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dotshare-container",
          "title": "DotShare",
          "icon": "assets/icons/icon.png"
        }
      ]
    },
    "views": {
      "dotshare-container": [
        {
          "id": "dotshareView",
          "name": "DotShare",
          "type": "webview",
          "icon": "assets/icons/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "dotshare.open",
        "title": "DotShare: Open Platform Hub",
        "icon": "$(home)"
      },
      {
        "command": "dotshare.generatePost",
        "title": "DotShare: Generate Social Media Post with AI"
      },
      {
        "command": "dotshare.shareToLinkedIn",
        "title": "DotShare: Share to LinkedIn"
      },
      {
        "command": "dotshare.shareToTelegram",
        "title": "DotShare: Share to Telegram"
      },
      {
        "command": "dotshare.shareToDevTo",
        "title": "DotShare: Publish article to Dev.to"
      },
      {
        "command": "dotshare.shareToMedium",
        "title": "DotShare: Publish article to Medium"
      },
      {
        "command": "dotshare.showAnalytics",
        "title": "DotShare: Show Analytics Dashboard",
        "icon": "$(graph-line)"
      },
      {
        "command": "dotshare.whatsNew",
        "title": "DotShare: What's New",
        "icon": "$(light-bulb)"
      }
    ],
    "uriHandlers": [
      {
        "scheme": "vscode",
        "authority": "freerave.dotshare"
      }
    ],
    "configuration": {
      "title": "DotShare",
      "properties": {
        "dotshare.customHashtags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom hashtags to always include in generated posts (e.g. [\"#OpenSource\", \"#VSCode\"]). The # prefix is optional."
        },
        "dotshare.defaultPlatform": {
          "type": "string",
          "enum": [
            "twitter",
            "linkedin",
            "facebook",
            "telegram",
            "discord",
            "reddit",
            "bluesky",
            "devto",
            "medium"
          ],
          "default": "twitter",
          "description": "Default platform used to tailor hashtag suggestions when generating a post."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "scheduler": "node bin/dotshare-scheduler.js",
    "cli": "node bin/dotshare-cli.js",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src media bin --ext ts,js",
    "test": "node ./out/test/runTest.js",
    "test:ai": "jest src/ai/__tests__",
    "test:all": "jest",
    "test:coverage": "jest --coverage",
    "publish:vscode": "vsce publish",
    "prepublish:npm": "cp package.json package.vscode.backup.json && cp package.cli.json package.json",
    "publish:npm": "npm publish",
    "postpublish:npm": "mv package.vscode.backup.json package.json"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "esbuild": "^0.25.11",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.0",
    "commander": "^11.1.0",
    "form-data": "^4.0.0",
    "open": "^8.4.2",
    "openai": "^6.0.1",
    "snoowrap": "^1.23.0"
  },
  "keywords": [
    "share",
    "social",
    "blog",
    "devto",
    "medium",
    "linkedin",
    "telegram",
    "twitter",
    "x",
    "facebook",
    "discord",
    "reddit",
    "bluesky",
    "ai",
    "gemini",
    "openai",
    "xai"
  ],
  "author": "FreeRave",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kareem2099/DotShare.git"
  },
  "homepage": "https://github.com/kareem2099/DotShare"
}
