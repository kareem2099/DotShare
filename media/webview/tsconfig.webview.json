{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ES2020",        // ← esbuild understands ES modules
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",                   // ← document, window, HTMLElement, etc.
      "DOM.Iterable"
    ],
    "outDir": "../../out/webview",
    "rootDir": ".",
    "strict": true,
    "noEmit": true             // ← esbuild handles the output, not tsc
  },
  "include": [
    "./**/*"
  ],
  "exclude": [
    "../../node_modules",
    "app.js",
    "app.js.map"
  ]
}
